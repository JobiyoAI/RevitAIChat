    "RevitMCP": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "mcp[cli]",
        "mcp",
        "run",
        "C:/Users/JAVI/Documents/VSCode/revit-mcp-python-new/main.py"
      ]
    },
